{
  "name": "@ozzyl/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/index.ts src/server.ts src/bootstrap.ts --format esm --dts --sourcemap --clean",
    "start": "node dist/server.js",
    "bootstrap": "tsx src/bootstrap.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@ozzyl/authentication": "*",
    "@ozzyl/billing": "*",
    "@ozzyl/risk-engine": "*",
    "@ozzyl/shared-types": "*",
    "@ozzyl/verification": "*",
    "hono": "^4.11.4",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5"
  }
}
