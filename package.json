{
  "name": "ozzyl-guard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*",
    "integrations/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "npm run dev -w @ozzyl/api",
    "dev:dashboard": "npm run dev -w @ozzyl/dashboard",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate --config packages/database/drizzle.config.ts",
    "db:migrate": "tsx packages/database/src/migrate.ts",
    "db:check": "tsx packages/database/src/check-migrations.ts",
    "check:architecture": "node scripts/check-architecture.mjs",
    "verify": "npm run format:check && npm run lint && npm run db:check && npm run check:architecture && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.39.2",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "turbo": "^2.8.13",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.53.0",
    "vitest": "^4.0.18"
  }
}
